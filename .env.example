# ═══════════════════════════════════════════════════════════════
#  CONVERA — Environment Variables
#  وزارة البلديات والإسكان — إدارة التطوير والتأهيل
#
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (Required) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<your-anon-key>

# Service role → server-side only, never expose to browser
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_<your-service-role-key>

# ─── Auth redirect URLs (set in Supabase dashboard) ───────────
# Auth → URL Configuration ₆ Redirect URLs:
#   https://convera.momah.gov.sa/reset-password
#   http://localhost:3000/reset-password
